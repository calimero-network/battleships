{
  "schema_version": "wasm-abi/1",
  "types": {
    "BattleshipState": {
      "kind": "record",
      "fields": [
        {
          "name": "id_nonce",
          "type": {
            "kind": "u64"
          }
        },
        {
          "name": "created_ms",
          "type": {
            "kind": "u64"
          }
        },
        {
          "name": "active_match",
          "type": {
            "$ref": "Match"
          },
          "nullable": true
        }
      ]
    },
    "Board": {
      "kind": "alias",
      "target": {
        "kind": "bytes"
      }
    },
    "Cell": {
      "kind": "variant",
      "variants": [
        {
          "name": "Empty"
        },
        {
          "name": "Ship"
        },
        {
          "name": "Hit"
        },
        {
          "name": "Miss"
        },
        {
          "name": "Pending"
        }
      ]
    },
    "Coordinate": {
      "kind": "record",
      "fields": [
        {
          "name": "x",
          "type": {
            "kind": "u32"
          }
        },
        {
          "name": "y",
          "type": {
            "kind": "u32"
          }
        }
      ]
    },
    "Fleet": {
      "kind": "record",
      "fields": [
        {
          "name": "ships",
          "type": {
            "kind": "list",
            "items": {
              "$ref": "Ship"
            }
          }
        }
      ]
    },
    "GameError": {
      "kind": "variant",
      "variants": [
        {
          "name": "NotFound",
          "payload": {
            "kind": "string"
          }
        },
        {
          "name": "Invalid",
          "payload": {
            "kind": "string"
          }
        },
        {
          "name": "Forbidden",
          "payload": {
            "kind": "string"
          }
        },
        {
          "name": "Finished"
        }
      ]
    },
    "Match": {
      "kind": "record",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "player1",
          "type": {
            "$ref": "PublicKey"
          }
        },
        {
          "name": "player2",
          "type": {
            "$ref": "PublicKey"
          }
        },
        {
          "name": "turn",
          "type": {
            "$ref": "PublicKey"
          }
        },
        {
          "name": "winner",
          "type": {
            "$ref": "PublicKey"
          },
          "nullable": true
        },
        {
          "name": "placed_p1",
          "type": {
            "kind": "bool"
          }
        },
        {
          "name": "placed_p2",
          "type": {
            "kind": "bool"
          }
        },
        {
          "name": "pending_x",
          "type": {
            "kind": "u32"
          },
          "nullable": true
        },
        {
          "name": "pending_y",
          "type": {
            "kind": "u32"
          },
          "nullable": true
        },
        {
          "name": "pending_shooter",
          "type": {
            "$ref": "PublicKey"
          },
          "nullable": true
        },
        {
          "name": "pending_target",
          "type": {
            "$ref": "PublicKey"
          },
          "nullable": true
        },
        {
          "name": "shots_p1",
          "type": {
            "$ref": "Board"
          }
        },
        {
          "name": "shots_p2",
          "type": {
            "$ref": "Board"
          }
        }
      ]
    },
    "OwnBoardView": {
      "kind": "record",
      "fields": [
        {
          "name": "size",
          "type": {
            "kind": "u32"
          }
        },
        {
          "name": "board",
          "type": {
            "kind": "bytes"
          }
        }
      ]
    },
    "PlayerBoard": {
      "kind": "record",
      "fields": [
        {
          "name": "own",
          "type": {
            "$ref": "Board"
          }
        },
        {
          "name": "ships",
          "type": {
            "kind": "u64"
          }
        },
        {
          "name": "placed",
          "type": {
            "kind": "bool"
          }
        }
      ]
    },
    "PublicKey": {
      "kind": "alias",
      "target": {
        "kind": "bytes",
        "size": 32
      }
    },
    "Ship": {
      "kind": "record",
      "fields": [
        {
          "name": "coordinates",
          "type": {
            "kind": "list",
            "items": {
              "$ref": "Coordinate"
            }
          }
        },
        {
          "name": "length",
          "type": {
            "kind": "u32"
          }
        }
      ]
    },
    "ShotsView": {
      "kind": "record",
      "fields": [
        {
          "name": "size",
          "type": {
            "kind": "u32"
          }
        },
        {
          "name": "shots",
          "type": {
            "kind": "bytes"
          }
        }
      ]
    },
    "ValidationInput": {
      "kind": "record",
      "fields": [
        {
          "name": "board",
          "type": {
            "$ref": "Board"
          },
          "nullable": true
        },
        {
          "name": "coordinates",
          "type": {
            "kind": "list",
            "items": {
              "$ref": "Coordinate"
            }
          },
          "nullable": true
        },
        {
          "name": "size",
          "type": {
            "kind": "u32"
          },
          "nullable": true
        },
        {
          "name": "ship_length",
          "type": {
            "kind": "u32"
          },
          "nullable": true
        },
        {
          "name": "fleet_composition",
          "type": {
            "kind": "list",
            "items": {
              "kind": "u32"
            }
          },
          "nullable": true
        },
        {
          "name": "ships",
          "type": {
            "kind": "list",
            "items": {
              "kind": "list",
              "items": {
                "$ref": "Coordinate"
              }
            }
          },
          "nullable": true
        }
      ]
    }
  },
  "methods": [
    {
      "name": "init",
      "params": [],
      "returns": {
        "kind": "unit"
      }
    },
    {
      "name": "create_match",
      "params": [
        {
          "name": "player2",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "kind": "string"
      }
    },
    {
      "name": "place_ships",
      "params": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "ships",
          "type": {
            "kind": "list",
            "items": {
              "kind": "string"
            }
          }
        }
      ],
      "returns": {
        "kind": "unit"
      }
    },
    {
      "name": "propose_shot",
      "params": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "x",
          "type": {
            "kind": "u32"
          }
        },
        {
          "name": "y",
          "type": {
            "kind": "u32"
          }
        }
      ],
      "returns": {
        "kind": "unit"
      }
    },
    {
      "name": "acknowledge_shot",
      "params": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "kind": "string"
      }
    },
    {
      "name": "get_own_board",
      "params": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "$ref": "OwnBoardView"
      }
    },
    {
      "name": "get_shots",
      "params": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "$ref": "ShotsView"
      }
    },
    {
      "name": "get_matches",
      "params": [],
      "returns": {
        "kind": "list",
        "items": {
          "kind": "string"
        }
      }
    },
    {
      "name": "get_active_match_id",
      "params": [],
      "returns": {
        "kind": "string"
      }
    },
    {
      "name": "get_current_turn",
      "params": [],
      "returns": {
        "kind": "string"
      }
    },
    {
      "name": "get_current_user",
      "params": [],
      "returns": {
        "kind": "string"
      }
    },
    {
      "name": "acknowledge_shot_handler",
      "params": [
        {
          "name": "id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "_x",
          "type": {
            "kind": "u32"
          }
        },
        {
          "name": "_y",
          "type": {
            "kind": "u32"
          }
        }
      ],
      "returns": {
        "kind": "unit"
      }
    }
  ],
  "events": [
    {
      "name": "MatchCreated"
    },
    {
      "name": "ShipsPlaced"
    },
    {
      "name": "ShotProposed"
    },
    {
      "name": "ShotFired"
    },
    {
      "name": "Winner"
    },
    {
      "name": "MatchEnded"
    }
  ],
  "state_root": "BattleshipState"
}