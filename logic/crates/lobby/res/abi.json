{
  "schema_version": "wasm-abi/1",
  "types": {
    "Event_MatchCreated": {
      "kind": "record",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "string"
          }
        }
      ]
    },
    "Event_MatchIdCollision": {
      "kind": "record",
      "fields": [
        {
          "name": "attempted_id",
          "type": {
            "kind": "string"
          }
        }
      ]
    },
    "LobbyState": {
      "kind": "record",
      "fields": [
        {
          "name": "created_ms",
          "type": {
            "kind": "record",
            "fields": [],
            "crdt_type": "lww_register",
            "inner_type": {
              "kind": "u64"
            }
          }
        },
        {
          "name": "matches",
          "type": {
            "kind": "map",
            "key": {
              "kind": "string"
            },
            "value": {
              "$ref": "MatchSummary"
            },
            "crdt_type": "unordered_map"
          }
        },
        {
          "name": "player_stats",
          "type": {
            "kind": "map",
            "key": {
              "kind": "string"
            },
            "value": {
              "$ref": "PlayerStats"
            },
            "crdt_type": "unordered_map"
          }
        },
        {
          "name": "history",
          "type": {
            "kind": "list",
            "items": {
              "$ref": "MatchRecord"
            },
            "crdt_type": "vector"
          }
        }
      ]
    },
    "MatchRecord": {
      "kind": "record",
      "fields": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "winner",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "loser",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "finished_ms",
          "type": {
            "kind": "u64"
          }
        }
      ]
    },
    "MatchStatus": {
      "kind": "variant",
      "variants": [
        {
          "name": "Pending"
        },
        {
          "name": "Active"
        },
        {
          "name": "Finished"
        }
      ]
    },
    "MatchSummary": {
      "kind": "record",
      "fields": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "player1",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "player2",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "status",
          "type": {
            "$ref": "MatchStatus"
          }
        },
        {
          "name": "context_id",
          "type": {
            "kind": "string"
          },
          "nullable": true
        },
        {
          "name": "winner",
          "type": {
            "kind": "string"
          },
          "nullable": true
        },
        {
          "name": "created_ms",
          "type": {
            "kind": "u64"
          }
        }
      ]
    },
    "PlayerStats": {
      "kind": "record",
      "fields": [
        {
          "name": "wins",
          "type": {
            "kind": "record",
            "fields": [],
            "crdt_type": "counter"
          }
        },
        {
          "name": "losses",
          "type": {
            "kind": "record",
            "fields": [],
            "crdt_type": "counter"
          }
        },
        {
          "name": "games_played",
          "type": {
            "kind": "record",
            "fields": [],
            "crdt_type": "counter"
          }
        }
      ]
    },
    "PlayerStatsView": {
      "kind": "record",
      "fields": [
        {
          "name": "wins",
          "type": {
            "kind": "u64"
          }
        },
        {
          "name": "losses",
          "type": {
            "kind": "u64"
          }
        },
        {
          "name": "games_played",
          "type": {
            "kind": "u64"
          }
        }
      ]
    }
  },
  "methods": [
    {
      "name": "new",
      "params": [
        {
          "name": "player_key",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "$ref": "PlayerStats"
      }
    },
    {
      "name": "to_view",
      "params": [],
      "returns": {
        "$ref": "PlayerStatsView"
      }
    },
    {
      "name": "init",
      "params": [],
      "returns": {
        "kind": "unit"
      }
    },
    {
      "name": "create_match",
      "params": [
        {
          "name": "player2",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "kind": "string"
      }
    },
    {
      "name": "set_match_context_id",
      "params": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "context_id",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "kind": "unit"
      }
    },
    {
      "name": "get_matches",
      "params": [],
      "returns": {
        "kind": "list",
        "items": {
          "$ref": "MatchSummary"
        }
      }
    },
    {
      "name": "get_player_stats",
      "params": [
        {
          "name": "player",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "$ref": "PlayerStatsView"
      }
    },
    {
      "name": "get_history",
      "params": [],
      "returns": {
        "kind": "list",
        "items": {
          "$ref": "MatchRecord"
        }
      }
    },
    {
      "name": "on_match_finished",
      "params": [
        {
          "name": "match_id",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "winner",
          "type": {
            "kind": "string"
          }
        },
        {
          "name": "loser",
          "type": {
            "kind": "string"
          }
        }
      ],
      "returns": {
        "kind": "unit"
      }
    }
  ],
  "events": [
    {
      "name": "MatchCreated",
      "payload": {
        "$ref": "Event_MatchCreated"
      }
    },
    {
      "name": "MatchIdCollision",
      "payload": {
        "$ref": "Event_MatchIdCollision"
      }
    },
    {
      "name": "MatchListUpdated"
    },
    {
      "name": "PlayerStatsUpdated"
    }
  ],
  "state_root": "LobbyState"
}