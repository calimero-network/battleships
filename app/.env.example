# Battleships app environment variables
#
# Copy this file to .env and adjust the values for your node and package setup.

# Registry package metadata used by mero-react during auth.
VITE_PACKAGE_NAME=com.calimero.battleships

# Optional registry URL for registry-based auth flows.
# VITE_REGISTRY_URL=http://localhost:8082

# Optional node URL that later login flow updates may read by default.
# VITE_NODE_URL=http://localhost:2428
